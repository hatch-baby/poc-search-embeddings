# Contentful CMS Configuration
# Get these from: https://app.contentful.com/spaces/[SPACE_ID]/api/keys
CONTENTFUL_SPACE_ID=hlsdh3zwyrtx
CONTENTFUL_ACCESS_TOKEN=your_contentful_access_token_here
CONTENTFUL_ENVIRONMENT=master

# VoyageAI API Configuration
# Get your API key from: https://www.voyageai.com/
VOYAGEAI_API_KEY=your_voyageai_api_key_here

# Storage Configuration
# STORAGE_MODE can be "postgres" or "memory"
# - memory: Store embeddings in-memory (no database needed, perfect for quick testing)
# - postgres: Store in PostgreSQL database (persistent storage)
STORAGE_MODE=memory

# PostgreSQL Database Configuration (only needed if STORAGE_MODE=postgres)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# If no password is set, use: postgresql://postgres@localhost:5432/embeddings_poc
# DATABASE_URL=postgresql://postgres:password@localhost:5432/embeddings_poc

# Optional: API Server Configuration
# PORT=3000
# HOST=localhost
# NODE_ENV=development
